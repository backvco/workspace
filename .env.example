# Workspace configuration. Copy to `.env` and fill in. The `.env` file is
# gitignored. Real environment variables (systemd, shell, container) override it.
#
# Values marked REQUIRED have no default — the server refuses to boot without them.

# --- REQUIRED ---

# Postgres connection string for the dedicated workspace database.
WORKSPACE_DATABASE_URL=postgres://user:password@127.0.0.1:5432/workspace

# Comma-separated absolute directories to scan for your projects/repos.
# This is the root the app works under — set it to where your code lives.
WORKSPACE_PROJECT_ROOTS=/home/you/code

# --- OPTIONAL (sensible defaults shown) ---

# Network bind for the standalone API. Keep on localhost unless you front it
# with your own auth / private mesh (Tailscale, NetBird, ZeroTier, reverse proxy).
WORKSPACE_HOST=127.0.0.1
WORKSPACE_PORT=5301

# Default working directory a fresh terminal opens in (defaults to the first
# entry of WORKSPACE_PROJECT_ROOTS).
# WORKSPACE_TERM_CWD=/home/you/code

# Where tab state + pasted images are stored (defaults to <app>/data).
# WORKSPACE_DATA_DIR=

# Where database backups (pg_dump) are written. Defaults to <data>/backups (chmod
# 600, gitignored). Manage + schedule them in Settings -> Backups.
# WORKSPACE_BACKUP_DIR=

# The agent CLI to drive. Required for now: Claude Code
# (npm install -g @anthropic-ai/claude-code, then run `claude` to log in).
WORKSPACE_CLAUDE_BIN=claude

# Public hostname when fronted by a reverse proxy (used for the dev-server host
# check and as an allowed WebSocket origin). Leave blank for localhost-only.
# WORKSPACE_PUBLIC_HOST=workspace.example.com
# Extra hostnames allowed to open the terminal WebSocket (comma-separated).
# Same-origin and WORKSPACE_PUBLIC_HOST are always allowed; set this only if the
# UI is served from a different host than the API.
# WORKSPACE_ALLOWED_ORIGINS=

# --- Embedded VS Code (optional) ---
# URL of a code-server instance to embed in the "Code" tab. Runtime config: set
# it and restart the API (no rebuild). Leave blank to hide the editor.
#   WORKSPACE_CODE_SERVER_URL=https://code.example.com
# SECURITY: code-server is a SEPARATE service and this app's auth does NOT protect
# it. The "Code" tab just iframes that URL, so anyone who can reach the URL gets a
# full editor + terminal (i.e. shell access) on this box. You MUST secure it:
#   - keep it reachable only over your private mesh (bind to the mesh IP), and/or
#   - put it behind the same reverse proxy + IP allowlist, and/or
#   - enable code-server's own auth:  code-server --auth password  (PASSWORD env).
# Also: code-server must allow being framed by your domain
#   (config.yaml / --... so its response doesn't send a blocking frame-ancestors).
# WORKSPACE_CODE_SERVER_URL=

# --- AUTH (optional) ---
# Auth is OFF by default and toggled in the in-app Settings tool. It's only
# needed if the server is reachable by people you don't trust. This key signs
# the session cookies — generate one with `openssl rand -hex 32`. Leave it blank
# to run without auth; enabling auth in Settings without a key set will fail.
WORKSPACE_SESSION_KEY=
