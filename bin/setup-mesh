#!/usr/bin/env bash
# setup-mesh <tailscale|netbird> - install a private-mesh client and enroll this
# server, so you can reach Workspace from your devices without exposing any ports
# to the public internet. Installs the client if it's missing.
set -euo pipefail

banner() { # W.ai wordmark: large W, small ai
  printf '\033[1;34m'
  cat <<'ART'
   __        __
   \ \      / /
    \ \ /\ / /
     \ V  V /
      \_/\_/  ai
ART
  printf '\033[0m\033[2m   Workspace AI  -  mesh setup\033[0m\n\n'
}
banner

KIND="${1:?usage: bin/setup-mesh <tailscale|netbird>}"
have() { command -v "$1" >/dev/null 2>&1; }
ask() { local p="$1" d="${2:-}" a=""; if [ -r /dev/tty ]; then printf '%s' "$p" > /dev/tty; read -r a < /dev/tty || a=""; fi; echo "${a:-$d}"; }
HOST_DEFAULT="$(hostname 2>/dev/null || echo workspace)"
nb_ip() { # THIS host's NetBird IP, empty if not connected
  local ip
  # The wt0 (WireGuard) interface holds this host's own address - authoritative, and
  # avoids accidentally grabbing a *peer's* IP out of `netbird status` output.
  ip="$(ip -4 -o addr 2>/dev/null | grep -E ' wt[0-9]' | grep -oE 'inet [0-9.]+' | awk '{print $2}' | head -1)"
  [ -n "$ip" ] && { echo "$ip"; return; }
  # Fallbacks if the interface name differs or `ip` is absent.
  ip="$(netbird status --json 2>/dev/null | grep -oE '"netbirdIp"[^,]*' | grep -oE '[0-9]+\.[0-9]+\.[0-9]+\.[0-9]+' | head -1)"
  [ -z "$ip" ] && ip="$(netbird status 2>/dev/null | grep -iE 'netbird ip' | grep -oE '[0-9]+\.[0-9]+\.[0-9]+\.[0-9]+' | head -1)"
  echo "$ip"
}

case "$KIND" in
  tailscale)
    # Already connected? Leave it alone unless the operator wants to reconfigure.
    if have tailscale && tailscale ip -4 >/dev/null 2>&1; then
      ip="$(tailscale ip -4 2>/dev/null | head -1)"
      echo "Tailscale is already connected. This device's mesh IP: $ip"
      case "$(ask 'Reconfigure (re-run tailscale up)? [y/N]: ' N)" in
        [Yy]*) : ;;
        *) echo "Keeping the existing connection. HTTPS on your tailnet: tailscale serve --bg 5300"; exit 0 ;;
      esac
    fi
    have tailscale || { echo "Installing Tailscale..."; curl -fsSL https://tailscale.com/install.sh | sh; }
    key="$(ask 'Tailscale auth key (blank = open a browser login): ' '')"
    name="$(ask "Device name [$HOST_DEFAULT]: " "$HOST_DEFAULT")"
    if [ -n "$key" ]; then sudo tailscale up --authkey "$key" --hostname "$name"
    else sudo tailscale up --hostname "$name"; fi
    ip="$(tailscale ip -4 2>/dev/null | head -1)"
    [ -n "$ip" ] && echo "Tailscale connected. This device's mesh IP: $ip" || echo "Tailscale connected (run 'tailscale ip -4' for the address)."
    echo "For HTTPS on your tailnet without a domain: tailscale serve --bg 5300"
    ;;

  netbird)
    # Already connected? Don't re-enroll (it could move the host to another
    # network) unless the operator explicitly asks to.
    if have netbird; then
      ip="$(nb_ip)"
      if [ -n "$ip" ]; then
        echo "NetBird is already connected. This device's mesh IP: $ip"
        case "$(ask 'Re-enroll with a different network/key? [y/N]: ' N)" in
          [Yy]*) : ;;
          *) echo "Keeping the existing connection. Point your domain's A record at $ip for DNS-01 TLS."; exit 0 ;;
        esac
      fi
    else
      echo "Installing NetBird..."; curl -fsSL https://pkgs.netbird.io/install.sh | sh
    fi
    # Override the management URL for a SELF-HOSTED NetBird; default is NetBird Cloud.
    mgmt="$(ask 'NetBird management URL [https://api.netbird.io] (override for self-hosted, include https://): ' 'https://api.netbird.io')"
    # NetBird needs a full URI - add the scheme if the user omitted it.
    case "$mgmt" in http://*|https://*) ;; *) mgmt="https://$mgmt" ;; esac
    key="$(ask 'NetBird setup key: ' '')"
    name="$(ask "Device name [$HOST_DEFAULT]: " "$HOST_DEFAULT")"
    [ -z "$key" ] && { echo "A setup key is required to enroll this server non-interactively."; exit 1; }
    echo "Enrolling against $mgmt as '$name'..."
    sudo netbird up --management-url "$mgmt" --setup-key "$key" --hostname "$name"
    sleep 2  # give the daemon a moment to assign the address
    ip="$(nb_ip)"
    if [ -n "$ip" ]; then
      echo "NetBird connected. This device's mesh IP: $ip"
      echo "Point your domain's A record at $ip for DNS-01 TLS."
    else
      echo "NetBird connected, but couldn't read the mesh IP - run: netbird status -d"
    fi
    ;;

  *) echo "unknown mesh: $KIND (use 'tailscale' or 'netbird')"; exit 1 ;;
esac
