#!/usr/bin/env bash
# dns-credentials <cloudflare|route53|google|digitalocean> <domain> [--export]
# dns-credentials import
#
# Creates a LEAST-PRIVILEGE DNS API credential for the DNS-01 ACME challenge and
# saves it to /etc/caddy/dns.env (chmod 600) for Caddy to read - so Caddy can prove
# domain ownership via a TXT record without exposing any public port.
#
# Requires the provider's CLI to be installed AND authenticated:
#   route53 -> aws,  google -> gcloud.   (Cloudflare/DigitalOcean have no CLI that
#   mints tokens, so you create a scoped token in their dashboard and paste it.)
#
# Run it wherever the CLI is authenticated:
#   - on the install box (it has cloud access):  dns-credentials google example.com
#   - on your laptop, then import on the box:     dns-credentials google example.com --export
#                                                 dns-credentials import   # on the box, paste the blob
set -euo pipefail

PROVIDER="${1:?usage: dns-credentials <cloudflare|route53|google|digitalocean> <domain> [--export]  |  dns-credentials import}"
ENVFILE="${CADDY_DNS_ENV:-/etc/caddy/dns.env}"

write_env() { # write_env KEY VALUE  -> chmod-600 dns.env Caddy reads
  sudo mkdir -p "$(dirname "$ENVFILE")"; sudo touch "$ENVFILE"; sudo chmod 600 "$ENVFILE"
  sudo sed -i "/^$1=/d" "$ENVFILE" 2>/dev/null || true
  echo "$1=$2" | sudo tee -a "$ENVFILE" >/dev/null
}

# Base64-decode, accepting GNU (-d) or BSD (-D). Arg is the string to decode.
b64d() { printf '%s' "$1" | base64 -d 2>/dev/null || printf '%s' "$1" | base64 -D 2>/dev/null; }
getval() { printf '%s\n' "$1" | sed -n "s/^$2=//p" | head -1; } # getval <content> <KEY>

# Actively check a decoded credential works against its provider (so a wrong/
# expired/under-scoped one is caught here, not later at cert time). Token providers
# are verified over HTTPS; AWS via the CLI if present; a GCP key is structurally
# validated (the real DNS test is Caddy's challenge - we can't test it without gcloud).
validate_content() {
  local c="$1" v j
  if printf '%s\n' "$c" | grep -q '^CLOUDFLARE_API_TOKEN='; then
    v="$(getval "$c" CLOUDFLARE_API_TOKEN)"
    curl -fsS -H "Authorization: Bearer $v" https://api.cloudflare.com/client/v4/user/tokens/verify 2>/dev/null | grep -q '"status":"active"'
  elif printf '%s\n' "$c" | grep -q '^DO_AUTH_TOKEN='; then
    v="$(getval "$c" DO_AUTH_TOKEN)"
    [ "$(curl -s -o /dev/null -w '%{http_code}' -H "Authorization: Bearer $v" https://api.digitalocean.com/v2/account 2>/dev/null)" = 200 ]
  elif printf '%s\n' "$c" | grep -q '^AWS_ACCESS_KEY_ID='; then
    command -v aws >/dev/null 2>&1 || return 0
    AWS_ACCESS_KEY_ID="$(getval "$c" AWS_ACCESS_KEY_ID)" AWS_SECRET_ACCESS_KEY="$(getval "$c" AWS_SECRET_ACCESS_KEY)" aws sts get-caller-identity >/dev/null 2>&1
  elif printf '%s\n' "$c" | grep -q '^GCP_KEY_B64='; then
    j="$(b64d "$(getval "$c" GCP_KEY_B64)")"
    # Require client_email AND a COMPLETE private key (END marker) - this catches a
    # truncated paste, which would otherwise be saved as an unusable key file.
    printf '%s' "$j" | grep -q 'client_email' && printf '%s' "$j" | grep -q 'END PRIVATE KEY'
  else
    return 0
  fi
}

# Persist credential content (KEY=VALUE lines; GCP_KEY_B64 becomes the key file).
save_content() {
  while IFS= read -r line; do
    [ -z "$line" ] && continue
    case "$line" in
      GCP_KEY_B64=*)
        sudo mkdir -p /etc/caddy
        b64d "${line#GCP_KEY_B64=}" | sudo tee /etc/caddy/gcp-dns.json >/dev/null
        sudo chmod 600 /etc/caddy/gcp-dns.json
        write_env GOOGLE_APPLICATION_CREDENTIALS /etc/caddy/gcp-dns.json ;;
      *=*) write_env "${line%%=*}" "${line#*=}" ;;
    esac
  done <<CONTENT
$1
CONTENT
  echo "saved to $ENVFILE"
}

# In --export mode print a paste-back blob; otherwise save to dns.env.
EXPORT=0; for a in "$@"; do if [ "$a" = --export ]; then EXPORT=1; fi; done
deliver() { # deliver <content>
  if [ "$EXPORT" = 1 ]; then
    # Wrap the blob across lines: a single ~4KB line gets truncated by the
    # terminal's canonical input buffer (~4096 bytes) when pasted into a read.
    echo
    echo "Copy the block between the dashed lines, paste into 'dns-credentials import':"
    echo "----------------------------------------------------------------------"
    printf '%s' "$1" | base64 | tr -d '\n' | fold -w 70
    echo
    echo "----------------------------------------------------------------------"
  else
    save_content "$1"
  fi
}

# --- import: paste a blob created elsewhere with --export ---
# Reads the WHOLE multi-line blob (a big key won't fit on one pasted line), strips
# any dashed/marker lines, hides input, and retries on a bad/incomplete paste.
if [ "$PROVIDER" = import ]; then
  while true; do
    echo "Paste the blob (all its lines), then press Enter. Ctrl-C to cancel."
    stty -echo 2>/dev/null || true
    raw=""; line=""
    IFS= read -r line < /dev/tty || true; raw="$line"
    # Drain the rest of the pasted lines; a 1s gap after the burst ends it (no Ctrl-D).
    while IFS= read -r -t 1 line < /dev/tty || [ -n "$line" ]; do raw="$raw
$line"; line=""; done
    stty echo 2>/dev/null || true
    echo
    b64="$(printf '%s' "$raw" | grep -vE '^-+[[:space:]]*$|====' | tr -d '[:space:]')"
    content="$(b64d "$b64")"
    if [ -z "$content" ] || ! printf '%s' "$content" | grep -q '='; then
      echo "That didn't decode (incomplete or wrong paste). Let's try again."; echo; continue
    fi
    echo "Checking the credential with the provider..."
    if validate_content "$content"; then
      save_content "$content"; echo "Credential verified."; exit 0
    fi
    echo "The credential decoded but FAILED to validate (wrong/expired token or too"
    echo "little scope). Fix it and paste again, or Ctrl-C to cancel."; echo
  done
fi

# --- verify: is a working credential for <provider> already in dns.env? ---
# Exit 0 = present (and valid if we can read it), 2 = present but invalid, 1 = absent.
# Presence is decided by the file EXISTING (no read needed). If it exists but we
# can't read it to validate (e.g. sudo needs a password), we still say "present"
# (exit 0) so the installer offers reuse instead of forcing a re-paste.
if [ "$PROVIDER" = verify ]; then
  prov="${2:-}"
  { [ -f "$ENVFILE" ] || sudo -n test -f "$ENVFILE" 2>/dev/null; } || exit 1
  envc="$(cat "$ENVFILE" 2>/dev/null || sudo -n cat "$ENVFILE" 2>/dev/null || true)"
  [ -n "$envc" ] || exit 0   # exists but unreadable -> treat as present/reusable
  case "$prov" in
    cloudflare)   printf '%s\n' "$envc" | grep -q '^CLOUDFLARE_API_TOKEN=' || exit 1 ;;
    digitalocean) printf '%s\n' "$envc" | grep -q '^DO_AUTH_TOKEN=' || exit 1 ;;
    route53)      printf '%s\n' "$envc" | grep -q '^AWS_ACCESS_KEY_ID=' || exit 1 ;;
    google)       printf '%s\n' "$envc" | grep -q '^GOOGLE_APPLICATION_CREDENTIALS=' || exit 1 ;;
    *) exit 1 ;;
  esac
  if [ "$prov" = google ]; then
    kf="$(getval "$envc" GOOGLE_APPLICATION_CREDENTIALS)"
    j="$(cat "$kf" 2>/dev/null || sudo -n cat "$kf" 2>/dev/null || true)"
    [ -n "$j" ] || exit 0   # key file present but unreadable here -> assume reusable
    if printf '%s' "$j" | grep -q client_email && printf '%s' "$j" | grep -q 'END PRIVATE KEY'; then exit 0; else exit 2; fi
  else
    if validate_content "$envc"; then exit 0; else exit 2; fi
  fi
fi

DOMAIN="${2:?domain required}"
# Registrable zone = last two labels (override with DNS_ZONE for TLDs like co.uk).
ZONE="${DNS_ZONE:-$(echo "$DOMAIN" | awk -F. '{print $(NF-1)"."$NF}')}"

case "$PROVIDER" in
  route53)
    command -v aws >/dev/null 2>&1 || { echo "ERROR: the AWS CLI is not installed. Install it, run 'aws configure', then re-run."; exit 1; }
    aws sts get-caller-identity >/dev/null 2>&1 || { echo "ERROR: the AWS CLI is not authenticated. Run 'aws configure' (admin creds), then re-run."; exit 1; }
    ZID="$(aws route53 list-hosted-zones-by-name --dns-name "$ZONE." --query 'HostedZones[0].Id' --output text | sed 's#/hostedzone/##')"
    { [ -z "$ZID" ] || [ "$ZID" = None ]; } && { echo "ERROR: no Route53 hosted zone found for $ZONE."; exit 1; }
    POLICY='{"Version":"2012-10-17","Statement":[{"Effect":"Allow","Action":["route53:ListHostedZonesByName","route53:GetChange"],"Resource":"*"},{"Effect":"Allow","Action":["route53:ChangeResourceRecordSets","route53:ListResourceRecordSets"],"Resource":"arn:aws:route53:::hostedzone/'"$ZID"'"}]}'
    echo "Creating a least-privilege IAM user scoped to zone $ZID..."
    aws iam create-user --user-name workspace-caddy-dns >/dev/null 2>&1 || true
    aws iam put-user-policy --user-name workspace-caddy-dns --policy-name caddy-dns --policy-document "$POLICY"
    CREDS="$(aws iam create-access-key --user-name workspace-caddy-dns --query 'AccessKey.[AccessKeyId,SecretAccessKey]' --output text)"
    deliver "AWS_ACCESS_KEY_ID=$(echo "$CREDS" | awk '{print $1}')
AWS_SECRET_ACCESS_KEY=$(echo "$CREDS" | awk '{print $2}')
AWS_REGION=${AWS_REGION:-us-east-1}"
    ;;

  google)
    command -v gcloud >/dev/null 2>&1 || { echo "ERROR: the gcloud CLI is not installed. Install it, run 'gcloud auth login', then re-run."; exit 1; }
    gcloud auth list --filter=status:ACTIVE --format='value(account)' 2>/dev/null | grep -q . || { echo "ERROR: gcloud is not authenticated. Run 'gcloud auth login', then re-run."; exit 1; }
    cfgp="$(gcloud config get-value project 2>/dev/null)"
    PROJECTS=()
    while IFS= read -r _p; do [ -n "$_p" ] && PROJECTS+=("$_p"); done < <(gcloud projects list --format='value(projectId)' 2>/dev/null)
    # Auto-detect which project actually hosts the Cloud DNS zone for the domain.
    printf 'Detecting which project hosts %s ' "$ZONE" >&2
    detected=""
    for _p in "${PROJECTS[@]}"; do
      printf '.' >&2
      if gcloud dns managed-zones list --project "$_p" --filter="dnsName=${ZONE}." --format='value(name)' 2>/dev/null | grep -q .; then detected="$_p"; break; fi
    done
    echo >&2
    defp="${detected:-$cfgp}"
    [ -n "$detected" ] && echo "Found the zone in project: $detected" || echo "Could not auto-detect the hosting project."
    echo "Your GCP projects:"
    i=1; for _p in "${PROJECTS[@]}"; do
      if [ "$_p" = "$detected" ]; then echo "  $i) $_p  (hosts $ZONE)"
      elif [ "$_p" = "$cfgp" ]; then echo "  $i) $_p  (current)"
      else echo "  $i) $_p"; fi
      i=$((i + 1))
    done
    read -r -p "Pick a number, or type a project id [$defp]: " sel < /dev/tty || sel=""
    if [ -z "$sel" ]; then PROJECT="$defp"
    elif [[ "$sel" =~ ^[0-9]+$ ]] && [ "$sel" -ge 1 ] && [ "$sel" -le "${#PROJECTS[@]}" ]; then PROJECT="${PROJECTS[$((sel - 1))]}"
    else PROJECT="$sel"; fi
    SA="workspace-caddy-dns@${PROJECT}.iam.gserviceaccount.com"
    # Least-privilege custom role: only DNS record/change ops (NOT full dns.admin).
    PERMS="dns.managedZones.get,dns.managedZones.list,dns.resourceRecordSets.create,dns.resourceRecordSets.delete,dns.resourceRecordSets.list,dns.resourceRecordSets.update,dns.changes.create,dns.changes.get,dns.changes.list"
    echo "Using project $PROJECT - creating a scoped service account + custom role..."
    gcloud iam roles create workspaceCaddyDns --project "$PROJECT" --title "Workspace Caddy DNS" --permissions "$PERMS" --stage GA >/dev/null 2>&1 \
      || gcloud iam roles update workspaceCaddyDns --project "$PROJECT" --add-permissions "$PERMS" >/dev/null 2>&1 || true
    gcloud iam service-accounts create workspace-caddy-dns --project "$PROJECT" --display-name "Workspace Caddy DNS" >/dev/null 2>&1 || true
    bound=0
    for _ in 1 2 3 4 5 6; do
      gcloud projects add-iam-policy-binding "$PROJECT" --member "serviceAccount:$SA" --role "projects/$PROJECT/roles/workspaceCaddyDns" >/dev/null 2>&1 && { bound=1; break; }
      sleep 5
    done
    [ "$bound" = 1 ] || { echo "ERROR: could not bind the custom role to $SA (does the project/zone exist?)."; exit 1; }
    tmpkey="$(mktemp)"
    gcloud iam service-accounts keys create "$tmpkey" --project "$PROJECT" --iam-account "$SA" >/dev/null
    deliver "GCP_PROJECT=$PROJECT
GCP_KEY_B64=$(base64 < "$tmpkey" | tr -d '\n')"
    rm -f "$tmpkey"
    ;;

  cloudflare)
    cat <<EOF
Cloudflare has no CLI that mints tokens - create one in the dashboard (30 sec):
  https://dash.cloudflare.com/profile/api-tokens  ->  Create Token  ->
  "Edit zone DNS" template  ->  Zone Resources: Include -> Specific zone -> $ZONE
  Permissions: Zone > DNS > Edit   (the only permission needed)
EOF
    read -rs -p "Paste the Cloudflare API token (hidden): " tok < /dev/tty; echo
    [ -n "$tok" ] || { echo "ERROR: no token provided."; exit 1; }
    deliver "CLOUDFLARE_API_TOKEN=$tok"
    ;;

  digitalocean)
    cat <<EOF
DigitalOcean has no CLI that mints tokens - create one in the dashboard:
  https://cloud.digitalocean.com/account/api/tokens  ->  Generate New Token  ->
  Scopes: select "domain" (read + write).
EOF
    read -rs -p "Paste the DigitalOcean token (hidden): " tok < /dev/tty; echo
    [ -n "$tok" ] || { echo "ERROR: no token provided."; exit 1; }
    deliver "DO_AUTH_TOKEN=$tok"
    ;;

  *) echo "unknown provider: $PROVIDER (cloudflare|route53|google|digitalocean|import)"; exit 1 ;;
esac
